{
  "enabled_tools": [
    "read_file",
    "write_file",
    "run_shell",
    "http_request"
  ],
  "upstream": {
    "base_url": "https://api.kimi.com/coding",
    "model": "kimi-k2.5-coding",
    "api_key_env": "ANTHROPIC_API_KEY",
    "chat_completions_path": "/v1/messages",
    "api_format": "claude",
    "timeout_seconds": 120,
    "context_window_tokens": 256000,
    "supports_vision_input": true
  },
  "skills_dirs": [
    "./skills"
  ],
  "system_prompt": "You are a pragmatic agent.",
  "max_tool_roundtrips": 12,
  "workspace_root": ".",
  "enable_context_compression": true,
  "effective_context_window_percent": 0.9,
  "retain_recent_messages": 8
}

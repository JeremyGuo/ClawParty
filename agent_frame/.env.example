# Agent Frame Environment Configuration
# Copy this file to .env or .env.test and fill in your actual values

# ============================================
# Claude API (Anthropic or compatible providers)
# ============================================

# Anthropic official API
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Kimi Coding (Claude-compatible)
ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
ANTHROPIC_API_KEY=sk-kimi-...

# ============================================
# OpenAI API (or compatible providers)
# ============================================

# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# Azure OpenAI
# AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=...

# ============================================
# Other Providers
# ============================================

# OpenRouter
# OPENROUTER_API_KEY=sk-or-v1-...

# ============================================
# Integration Test Configuration
# ============================================

# Set to "true" to enable live API tests (requires valid API keys)
# ENABLE_LIVE_TESTS=false

# Test-specific model selection
# TEST_CLAUDE_MODEL=claude-3-5-sonnet-20241022
# TEST_OPENAI_MODEL=gpt-4

{
  "enabled_tools": [
    "read_file",
    "write_file",
    "run_shell",
    "http_request"
  ],
  "upstream": {
    "base_url": "https://openrouter.ai/api/v1",
    "model": "openai/gpt-5-mini",
    "api_key_env": "OPENROUTER_API_KEY",
    "timeout_seconds": 120,
    "context_window_tokens": 400000,
    "cache_control": {
      "type": "ephemeral",
      "ttl": "1h"
    },
    "reasoning": {
      "effort": "high"
    }
  },
  "skills_dirs": [
    "./skills"
  ],
  "system_prompt": "You are a pragmatic agent.",
  "max_tool_roundtrips": 12,
  "workspace_root": ".",
  "enable_context_compression": true,
  "effective_context_window_percent": 0.9,
  "retain_recent_messages": 8
}

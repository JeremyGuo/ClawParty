#!/bin/sh
set -eu
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [ -x "$SCRIPT_DIR/target/release/run_agent" ]; then
  exec "$SCRIPT_DIR/target/release/run_agent" "$@"
fi
if [ -x "$SCRIPT_DIR/target/debug/run_agent" ]; then
  exec "$SCRIPT_DIR/target/debug/run_agent" "$@"
fi
exec cargo run --manifest-path "$SCRIPT_DIR/Cargo.toml" --quiet --bin run_agent -- "$@"


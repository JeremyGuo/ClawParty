{
  "enabled_tools": [
    "read_file",
    "write_file",
    "run_shell",
    "http_request"
  ],
  "upstream": {
    "base_url": "https://api.openai.com/v1",
    "model": "gpt-4.1",
    "api_key_env": "OPENAI_API_KEY",
    "timeout_seconds": 120,
    "context_window_tokens": 128000
  },
  "skills_dirs": [
    "./skills"
  ],
  "system_prompt": "You are a pragmatic agent.",
  "max_tool_roundtrips": 12,
  "workspace_root": ".",
  "enable_context_compression": true,
  "effective_context_window_percent": 0.9,
  "retain_recent_messages": 8
}
